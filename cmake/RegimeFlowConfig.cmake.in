@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(@REGIMEFLOW_PACKAGE_NEEDS_BOOST_SYSTEM@)
    find_dependency(Boost REQUIRED COMPONENTS system)
endif()

if(@REGIMEFLOW_PACKAGE_NEEDS_CURL@)
    find_dependency(CURL REQUIRED)
endif()

if(@REGIMEFLOW_PACKAGE_NEEDS_OPENSSL@)
    find_dependency(OpenSSL REQUIRED)
endif()

if(@REGIMEFLOW_PACKAGE_NEEDS_POSTGRES@)
    find_dependency(PostgreSQL REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/RegimeFlowTargets.cmake")
